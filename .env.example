# راشد - متغيرات البيئة المطلوبة
# انسخ هذا الملف وسمّه .env ثم أضف قيمك
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# توكنات البوتات
MAIN_BOT_TOKEN=your_main_bot_token_here
TRACKER_BOT_TOKEN=your_tracker_bot_token_here

# معرّفات تيليغرام
ADMIN_ID=your_telegram_user_id
TARGET_CHANNEL_ID=-1003770774871
CONTROL_CHANNEL_ID=-1003751955886

# مفاتيح API
GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key
VIRUSTOTAL_API_KEY=your_virustotal_api_key
DEHASHED_API_KEY=your_dehashed_api_key
IPINFO_TOKEN=your_ipinfo_token

# رابط السيرفر
BOT_SERVER_URL=your_server_url_here